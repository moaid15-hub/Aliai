// ============================================
// 🔍 نظام البحث الموحد النهائي
// يجمع كل المميزات من search.ts و web-search.ts
// ============================================

// 📝 Types & Interfaces
interface SearchResult {
  title: string;
  url: string;
  snippet: string;
  content: string;
  relevanceScore?: number;
  displayLink?: string;
  formattedUrl?: string;
  image?: {
    contextLink?: string;
    height?: number;
    width?: number;
    thumbnailLink?: string;
  };
}

interface SearchResponse {
  results: SearchResult[];
  query: string;
  totalResults: string | number;
  searchTime: number;
  source: string;
}

interface MultiSourceResult {
  source: 'google' | 'youtube' | 'wikipedia' | 'stackoverflow';
  results: SearchResult[];
  totalResults: string | number;
  searchTime: number;
}

interface MultiSourceResponse {
  sources: MultiSourceResult[];
  query: string;
  totalSearchTime: number;
}

interface GoogleSearchConfig {
  apiKey: string;
  searchEngineId: string;
  language?: string;
  country?: string;
  safeSearch?: 'off' | 'medium' | 'high';
  numResults?: number;
}

interface SearchOptions {
  maxResults?: number;
  timeout?: number;
  recentOnly?: boolean;
  exactMatch?: boolean;
  fastMode?: boolean; // جديد: للبحث السريع
  retries?: number;
  multiSource?: boolean; // جديد: للبحث من مصادر متعددة
}

// ⚙️ Default Configuration
const DEFAULT_CONFIG = {
  language: 'ar',
  country: 'sa',
  safeSearch: 'medium' as const,
  numResults: 5,
  timeout: 10000,
  fastTimeout: 3000, // للبحث السريع
  maxRetries: 3,
  fastRetries: 1 // للبحث السريع
};

// ============================================
// 💾 Cache System
// ============================================

interface CacheEntry {
  data: SearchResponse;
  timestamp: number;
}

class SearchCache {
  private cache: Map<string, CacheEntry>;
  private maxAge: number;
  private maxSize: number;

  constructor(maxAge: number = 30 * 60 * 1000, maxSize: number = 200) {
    this.cache = new Map();
    this.maxAge = maxAge;
    this.maxSize = maxSize;
  }

  private generateKey(query: string, options: any): string {
    return `${query}_${options.language}_${options.numResults}`;
  }

  set(query: string, options: any, data: SearchResponse): void {
    const key = this.generateKey(query, options);
    
    if (this.cache.size >= this.maxSize) {
      const firstKey = this.cache.keys().next().value;
      if (firstKey) this.cache.delete(firstKey);
    }

    this.cache.set(key, { data, timestamp: Date.now() });
  }

  get(query: string, options: any): SearchResponse | null {
    const key = this.generateKey(query, options);
    const entry = this.cache.get(key);

    if (!entry) return null;

    if (Date.now() - entry.timestamp > this.maxAge) {
      this.cache.delete(key);
      return null;
    }

    return entry.data;
  }

  clear(): void {
    this.cache.clear();
  }

  getStats() {
    return {
      size: this.cache.size,
      maxSize: this.maxSize,
      maxAge: this.maxAge
    };
  }
}

const searchCache = new SearchCache();

// ============================================
// 📊 Usage Tracker
// ============================================

class UsageTracker {
  private dailyUsage: Map<string, number>;
  private maxDailyQueries: number;

  constructor(maxDailyQueries: number = 100) {
    this.dailyUsage = new Map();
    this.maxDailyQueries = maxDailyQueries;
  }

  private getTodayKey(): string {
    return new Date().toISOString().split('T')[0];
  }

  canSearch(): boolean {
    const today = this.getTodayKey();
    const usage = this.dailyUsage.get(today) || 0;
    return usage < this.maxDailyQueries;
  }

  incrementUsage(): void {
    const today = this.getTodayKey();
    const current = this.dailyUsage.get(today) || 0;
    this.dailyUsage.set(today, current + 1);
  }

  getUsage() {
    const today = this.getTodayKey();
    const used = this.dailyUsage.get(today) || 0;
    return {
      used,
      remaining: this.maxDailyQueries - used,
      limit: this.maxDailyQueries
    };
  }

  resetDaily(): void {
    const today = this.getTodayKey();
    this.dailyUsage.clear();
    this.dailyUsage.set(today, 0);
  }
}

const usageTracker = new UsageTracker(100);

