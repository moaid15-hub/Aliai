/**
 * الحصول على إحصائيات الـ Cache
 */
export function getCacheStats() {
  return googleSearchCache.getStats();
}

/**
 * مسح الـ Cache
 */
export function clearCache() {
  googleSearchCache.clear();
  console.log('🗑️ تم مسح Cache');
}

/**
 * الحصول على إحصائيات الاستخدام
 */
export function getUsageStats() {
  return usageTracker.getUsage();
}

/**
 * إعادة تعيين عداد الاستخدام اليومي
 */
export function resetUsage() {
  usageTracker.resetDaily();
  console.log('🔄 تم إعادة تعيين عداد الاستخدام');
}

/**
 * بحث محمي مع التحقق من الحد اليومي
 */
export async function protectedSearch(
  query: string,
  options?: {
    maxResults?: number;
    recentOnly?: boolean;
    exactMatch?: boolean;
  }
): Promise<string> {
  // تحقق من الحد اليومي
  if (!usageTracker.canSearch()) {
    const usage = usageTracker.getUsage();
    return `عذراً، وصلت للحد الأقصى من البحث اليوم! 📊\n\nاستخدمت ${usage.used} من ${usage.limit} استعلام.\nحاول بكرة! 😊`;
  }

  try {
    const result = await searchWeb(query, options);
    return formatSearchResults(result);
  } catch (error) {
    console.error('❌ خطأ في البحث المحمي:', error);
    return `عذراً، حصل خطأ أثناء البحث 😕\n\nممكن تحاول مرة ثانية؟`;
  }
}

