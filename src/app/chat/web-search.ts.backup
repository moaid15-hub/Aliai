// ============================================
// 🌐 نظام البحث على الإنترنت - Web Search System
// كل شيء يخص البحث العام في ملف واحد
// مدمج مع Google Custom Search API
// ============================================

// 📝 Types & Interfaces
interface SearchResult {
  title: string;
  url: string;
  snippet: string;
  content: string;
  relevanceScore?: number;
  displayLink?: string;
  formattedUrl?: string;
  image?: {
    contextLink?: string;
    height?: number;
    width?: number;
    thumbnailLink?: string;
  };
}

interface SearchResponse {
  results: SearchResult[];
  query: string;
  totalResults: string | number;
  searchTime: number;
  source: string;
}

interface GoogleSearchConfig {
  apiKey: string;
  searchEngineId: string;
  language?: string;
  country?: string;
  safeSearch?: 'off' | 'medium' | 'high';
  numResults?: number;
}

// ⚙️ Default Configuration
const DEFAULT_GOOGLE_CONFIG: Partial<GoogleSearchConfig> = {
  language: 'ar',
  country: 'sa',
  safeSearch: 'medium',
  numResults: 5
};

// ============================================
// 💾 Google Search Cache System
// ============================================

interface CacheEntry {
  data: SearchResponse;
  timestamp: number;
}

class GoogleSearchCache {
  private cache: Map<string, CacheEntry>;
  private maxAge: number;
  private maxSize: number;

  constructor(maxAge: number = 30 * 60 * 1000, maxSize: number = 200) {
    this.cache = new Map();
    this.maxAge = maxAge;
    this.maxSize = maxSize;
  }

  private generateKey(query: string, config: GoogleSearchConfig): string {
    return `${query}_${config.language}_${config.country}_${config.numResults}`;
  }

  set(query: string, config: GoogleSearchConfig, data: SearchResponse): void {
    const key = this.generateKey(query, config);
    
    // إذا وصلنا للحد الأقصى، احذف الأقدم
    if (this.cache.size >= this.maxSize) {
      const firstKey = this.cache.keys().next().value;
      if (firstKey) {
        this.cache.delete(firstKey);
      }
    }

    this.cache.set(key, {
      data,
      timestamp: Date.now()
    });
  }

  get(query: string, config: GoogleSearchConfig): SearchResponse | null {
    const key = this.generateKey(query, config);
    const entry = this.cache.get(key);

    if (!entry) return null;

    // تحقق من الصلاحية
    if (Date.now() - entry.timestamp > this.maxAge) {
      this.cache.delete(key);
      return null;
    }

    return entry.data;
  }

  clear(): void {
    this.cache.clear();
  }

  getStats(): { size: number; maxSize: number; maxAge: number } {
    return {
      size: this.cache.size,
      maxSize: this.maxSize,
      maxAge: this.maxAge
    };
  }
}

const googleSearchCache = new GoogleSearchCache();

// ============================================
// 📊 Usage Tracker System
// ============================================

class SearchUsageTracker {
  private dailyUsage: Map<string, number>;
  private maxDailyQueries: number;

  constructor(maxDailyQueries: number = 100) {
    this.dailyUsage = new Map();
    this.maxDailyQueries = maxDailyQueries;
  }

  private getTodayKey(): string {
    return new Date().toISOString().split('T')[0];
  }

  canSearch(): boolean {
    const today = this.getTodayKey();
    const usage = this.dailyUsage.get(today) || 0;
    return usage < this.maxDailyQueries;
  }

  incrementUsage(): void {
    const today = this.getTodayKey();
    const current = this.dailyUsage.get(today) || 0;
    this.dailyUsage.set(today, current + 1);
  }

  getUsage(): { used: number; remaining: number; limit: number } {
    const today = this.getTodayKey();
    const used = this.dailyUsage.get(today) || 0;
    return {
      used,
      remaining: this.maxDailyQueries - used,
      limit: this.maxDailyQueries
    };
  }

  resetDaily(): void {
    const today = this.getTodayKey();
    this.dailyUsage.clear();
    this.dailyUsage.set(today, 0);
  }
}

const usageTracker = new SearchUsageTracker(100);

// ============================================
// 🔍 Google Custom Search API
// ============================================

/**
 * البحث باستخدام Google Custom Search
 */
async function googleSearch(
  query: string,
  config: GoogleSearchConfig
): Promise<SearchResponse> {
  const startTime = Date.now();

  // تحقق من الـ Cache أولاً
  const cachedResult = googleSearchCache.get(query, config);
  if (cachedResult) {
    console.log('✅ نتيجة من الـ Cache');
    return cachedResult;
  }

  // بناء URL للـ API
  const params = new URLSearchParams({
    key: config.apiKey,
    cx: config.searchEngineId,
    q: query,
    num: (config.numResults || 5).toString(),
    lr: `lang_${config.language || 'ar'}`,
    gl: config.country || 'sa',
    safe: config.safeSearch || 'medium'
  });

  const url = `https://www.googleapis.com/customsearch/v1?${params.toString()}`;

  console.log('🔍 Google Search API:', query);

  const response = await fetch(url, {
    method: 'GET',
    headers: {
      'Accept': 'application/json'
    }
  });

  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Google Search API error: ${response.status} - ${errorText}`);
  }

  const data = await response.json();

  const searchResponse: SearchResponse = {
    results: (data.items || []).map((item: any) => ({
      title: item.title || 'بدون عنوان',
      url: item.link || '',
      snippet: item.snippet || '',
      content: item.snippet || '',
      displayLink: item.displayLink,
      formattedUrl: item.formattedUrl,
      relevanceScore: 0.9,
      image: item.pagemap?.cse_image?.[0]
    })),
    query: query,
    totalResults: data.searchInformation?.totalResults || '0',
    searchTime: Date.now() - startTime,
    source: 'Google Custom Search'
  };

  // حفظ في الـ Cache
  googleSearchCache.set(query, config, searchResponse);

  return searchResponse;
}

/**
 * بحث مع إعادة المحاولة عند الفشل
 */
async function googleSearchWithRetry(
  query: string,
  config: GoogleSearchConfig,
  maxRetries: number = 3,
  retryDelay: number = 1000
): Promise<SearchResponse> {
  let lastError: Error | null = null;

  for (let attempt = 1; attempt <= maxRetries; attempt++) {
    try {
      return await googleSearch(query, config);
    } catch (error) {
      lastError = error as Error;
      console.error(`❌ محاولة ${attempt} فشلت:`, error);

      if (attempt < maxRetries) {
        console.log(`🔄 إعادة المحاولة بعد ${retryDelay * attempt}ms...`);
        await new Promise(resolve => setTimeout(resolve, retryDelay * attempt));
      }
    }
  }

  throw lastError || new Error('فشل البحث بعد عدة محاولات');
}

/**
 * بحث ذكي مع خيارات إضافية
 */
async function smartGoogleSearch(
  query: string,
  config: GoogleSearchConfig,
  options?: {
    recentOnly?: boolean;
    exactMatch?: boolean;
  }
): Promise<SearchResponse> {
  let modifiedQuery = query;

  // بحث عن نتائج حديثة فقط
  if (options?.recentOnly) {
    const lastYear = new Date();
    lastYear.setFullYear(lastYear.getFullYear() - 1);
    modifiedQuery += ` after:${lastYear.getFullYear()}`;
  }

  // بحث دقيق
  if (options?.exactMatch) {
    modifiedQuery = `"${query}"`;
  }

  return await googleSearchWithRetry(modifiedQuery, config);
}

// ============================================
// 🎯 Keywords & Detection
// ============================================

const SEARCH_KEYWORDS = [
  // البحث المباشر
  'ابحث عن', 'دور على', 'ابحث لي عن', 'find me', 'search for',
  'معلومات عن', 'أريد معرفة', 'أخبرني عن', 'وضح لي',
  
  // الأخبار والأحداث
  'آخر أخبار', 'أحدث', 'جديد في', 'ما الجديد', 'latest news',
  'أخبار اليوم', 'حديث عن', 'الأخبار', 'ما يحدث',
  
  // المقارنات
  'قارن بين', 'مقارنة', 'الفرق بين', 'أيهما أفضل',
  'ما أفضل', 'compare', 'which is better',
  
  // الأسعار
  'سعر', 'كم سعر', 'كم يكلف', 'تكلفة', 'price', 'cost',
  
  // التواريخ
  'متى', 'تاريخ', 'موعد', 'when', 'date',
  
  // الإحصائيات
  'إحصائيات', 'أرقام', 'بيانات', 'statistics', 'data',
  
  // موضوعات تحتاج بحث حديث
  'الطقس', 'weather', 'الأسهم', 'stock', 'البورصة'
];

// ❌ التحيات والمحادثات العامة (لا تحتاج بحث)
const EXCLUDE_PATTERNS = [
  'مرحبا', 'مرحباً', 'أهلا', 'سلام', 'السلام عليكم',
  'صباح الخير', 'مساء الخير', 'شكرا', 'شكراً',
  'hello', 'hi', 'hey', 'thanks', 'bye',
  'كيف حالك', 'كيفك', 'how are you', 'ما اسمك'
];

/**
 * 🤔 هل السؤال يحتاج بحث؟
 */
export function needsWebSearch(query: string): boolean {
  const lowerQuery = query.toLowerCase().trim();
  
  // استبعاد التحيات
  if (lowerQuery.length < 8) return false;
  if (EXCLUDE_PATTERNS.some(p => lowerQuery.includes(p))) return false;
  
  // البحث عن كلمات مفتاحية
  const hasKeywords = SEARCH_KEYWORDS.some(k => lowerQuery.includes(k.toLowerCase()));
  
  // أنماط إضافية
  const hasSearchPatterns = [
    /\b(في|من|حول|عن|about|of)\s+\w{4,}/g,
    /\b(كيف|how)\s+(يمكن|can)\s+\w+/g,
    /\b(ما هو|what is)\s+\w{3,}/g,
    /\b(أين|where)\s+(يقع|is)\s+\w+/g,
    /\d{4}|\b(عام|سنة|year)\b/g,
  ].some(pattern => pattern.test(lowerQuery));
  
  const isLongQuery = lowerQuery.length > 15;
  const needsSearch = hasKeywords || hasSearchPatterns || isLongQuery;
  
  console.log('🤔 تحليل البحث:', {
    query: lowerQuery.substring(0, 50),
    hasKeywords,
    hasPatterns: hasSearchPatterns,
    isLong: isLongQuery,
    needsSearch
  });
  
  return needsSearch;
}

/**
 * 🌐 البحث في الإنترنت - الدالة الرئيسية
 * الأولوية: Smart Multi-Source → Google → Tavily → Serper → Fallback
 */
export async function searchWeb(
  query: string,
  options: {
    maxResults?: number;
    timeout?: number;
    recentOnly?: boolean;
    exactMatch?: boolean;
    useSmartSearch?: boolean; // جديد: استخدام البحث الذكي
  } = {}
): Promise<SearchResponse> {
  const { 
    maxResults = 5, 
    timeout = 10000, 
    recentOnly, 
    exactMatch,
    useSmartSearch = false // تفعيل البحث الذكي
  } = options;
  const startTime = Date.now();
  
  console.log('🔍 بحث في الإنترنت:', query);

  // 🧠 البحث الذكي متعدد المصادر (إذا مفعّل)
  if (useSmartSearch) {
    try {
      const { smartMultiSourceSearch } = await import('./smart-multi-source-search');
      console.log('🧠 استخدام البحث الذكي متعدد المصادر...');
      
      const smartResult = await smartMultiSourceSearch(query, { maxResults });
      
      if (smartResult.primary) {
        // تحويل النتيجة الذكية لتنسيق SearchResponse
        return {
          results: smartResult.primary.results.map(r => ({
            title: r.title,
            url: r.url,
            snippet: r.snippet,
            content: r.snippet,
            relevanceScore: 0.9
          })),
          query: query,
          totalResults: smartResult.primary.results.length,
          searchTime: Date.now() - startTime,
          source: `Smart Search: ${smartResult.primary.source}`
        };
      }
    } catch (error) {
      console.warn('⚠️ البحث الذكي فشل، التحويل للبحث العادي:', error);
    }
  }

  // تحقق من الحد اليومي لـ Google Search
  const canUseGoogle = usageTracker.canSearch();
  
  // 1️⃣ أولوية أولى: Google Custom Search
  if (canUseGoogle) {
    const googleApiKey = process.env.GOOGLE_SEARCH_API_KEY;
    const googleEngineId = process.env.GOOGLE_SEARCH_ENGINE_ID;
    
    if (googleApiKey && googleEngineId) {
      try {
        console.log('🔍 محاولة Google Custom Search...');
        usageTracker.incrementUsage();
        
        const googleConfig: GoogleSearchConfig = {
          apiKey: googleApiKey,
          searchEngineId: googleEngineId,
          language: 'ar',
          country: 'sa',
          safeSearch: 'medium',
          numResults: maxResults
        };

        const result = await smartGoogleSearch(query, googleConfig, {
          recentOnly,
          exactMatch
        });

        console.log('✅ Google Search نجح!');
        return result;

      } catch (error) {
        console.warn('⚠️ Google Search فشل:', error);
        
        // معالجة أخطاء محددة
        const errorMsg = (error as Error).message;
        if (errorMsg.includes('quota') || errorMsg.includes('limit')) {
          console.log('📊 تم تجاوز حد Google API');
        }
      }
    } else {
      console.log('⚠️ مفاتيح Google Search غير موجودة');
    }
  } else {
    const usage = usageTracker.getUsage();
    console.log(`📊 تم استنفاذ حد Google: ${usage.used}/${usage.limit}`);
  }
  
  // 2️⃣ أولوية ثانية: Tavily API
  try {
    const tavilyResult = await searchWithTavily(query, maxResults, timeout);
    if (tavilyResult) {
      return {
        ...tavilyResult,
        searchTime: Date.now() - startTime
      };
    }
  } catch (error) {
    console.warn('⚠️ Tavily فشل:', error);
  }
  
  // 3️⃣ أولوية ثالثة: Serper API
  try {
    const serperResult = await searchWithSerper(query, maxResults, timeout);
    if (serperResult) {
      return {
        ...serperResult,
        searchTime: Date.now() - startTime
      };
    }
  } catch (error) {
    console.warn('⚠️ Serper فشل:', error);
  }
  
  // 4️⃣ نتائج افتراضية (fallback)
  console.log('ℹ️ استخدام نتائج افتراضية');
  return generateFallbackResults(query, maxResults, Date.now() - startTime);
}

/**
 * 🔍 البحث باستخدام Tavily
 */
async function searchWithTavily(
  query: string,
  maxResults: number,
  timeout: number
): Promise<SearchResponse | null> {
  const apiKey = process.env.TAVILY_API_KEY;
  if (!apiKey) return null;
  
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), timeout);
    
    const response = await fetch('https://api.tavily.com/search', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        api_key: apiKey,
        query: query,
        max_results: maxResults,
        search_depth: 'basic',
        include_answer: true
      }),
      signal: controller.signal
    });
    
    clearTimeout(timeoutId);
    
    if (!response.ok) return null;
    
    const data = await response.json();
    
    return {
      results: data.results?.map((r: any) => ({
        title: r.title || 'بدون عنوان',
        url: r.url || '',
        snippet: r.content || r.snippet || '',
        content: r.content || r.snippet || '',
        relevanceScore: r.score || 0.5
      })) || [],
      query: query,
      totalResults: data.results?.length || 0,
      searchTime: 0,
      source: 'Tavily Search'
    };
  } catch (error) {
    console.error('خطأ Tavily:', error);
    return null;
  }
}

/**
 * 🔍 البحث باستخدام Serper
 */
async function searchWithSerper(
  query: string,
  maxResults: number,
  timeout: number
): Promise<SearchResponse | null> {
  const apiKey = process.env.SERPER_API_KEY;
  if (!apiKey) return null;
  
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), timeout);
    
    const response = await fetch('https://google.serper.dev/search', {
      method: 'POST',
      headers: {
        'X-API-KEY': apiKey,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        q: query,
        num: maxResults
      }),
      signal: controller.signal
    });
    
    clearTimeout(timeoutId);
    
    if (!response.ok) return null;
    
    const data = await response.json();
    
    return {
      results: data.organic?.slice(0, maxResults).map((r: any) => ({
        title: r.title || 'بدون عنوان',
        url: r.link || '',
        snippet: r.snippet || '',
        content: r.snippet || '',
        relevanceScore: 0.8
      })) || [],
      query: query,
      totalResults: data.organic?.length || 0,
      searchTime: 0,
      source: 'Google Search (Serper)'
    };
  } catch (error) {
    console.error('خطأ Serper:', error);
    return null;
  }
}

/**
 * 📋 نتائج افتراضية في حالة فشل كل APIs
 */
function generateFallbackResults(
  query: string,
  maxResults: number,
  searchTime: number
): SearchResponse {
  const isArabic = /[\u0600-\u06FF]/.test(query);
  
  return {
    results: [
      {
        title: isArabic ? `نتائج عن: ${query}` : `Results for: ${query}`,
        url: `https://www.google.com/search?q=${encodeURIComponent(query)}`,
        snippet: isArabic 
          ? `للحصول على نتائج محدثة حول "${query}"، يُنصح بزيارة محركات البحث مباشرة.`
          : `For updated results about "${query}", please visit search engines directly.`,
        content: isArabic
          ? `معلومات عامة حول ${query}. للحصول على تفاصيل أكثر دقة، يُفضل البحث في مصادر متخصصة.`
          : `General information about ${query}. For more accurate details, please search specialized sources.`,
        relevanceScore: 0.5
      }
    ],
    query: query,
    totalResults: 1,
    searchTime: searchTime,
    source: 'Fallback Results'
  };
}

/**
 * 🎯 تنسيق النتائج للعرض - محسّن لـ Google Search
 */
export function formatSearchResults(response: SearchResponse): string {
  const { results, query, source, totalResults, searchTime } = response;
  
  if (!results || results.length === 0) {
    return `عذراً، لم أجد نتائج عن "${query}" 🔍\n\nجرّب تغيير كلمات البحث أو استخدم مصطلحات مختلفة!`;
  }
  
  let formatted = `� **نتائج البحث عن: "${query}"**\n\n`;
  
  // إحصائيات البحث
  if (typeof totalResults === 'string' && totalResults !== '0') {
    const total = parseInt(totalResults);
    if (!isNaN(total)) {
      formatted += `📊 وجدت حوالي **${total.toLocaleString('ar')}** نتيجة`;
    }
  } else if (typeof totalResults === 'number' && totalResults > 0) {
    formatted += `📊 وجدت **${totalResults}** نتيجة`;
  }
  
  formatted += ` في ${(searchTime / 1000).toFixed(2)} ثانية\n`;
  formatted += `🔎 المصدر: **${source}**\n\n`;
  formatted += `---\n\n`;
  
  // النتائج
  results.forEach((result, index) => {
    formatted += `**${index + 1}. ${result.title}**\n\n`;
    
    // عرض الرابط المختصر إن وُجد
    if (result.displayLink) {
      formatted += `🌐 ${result.displayLink}\n`;
    }
    
    formatted += `${result.snippet}\n\n`;
    formatted += `🔗 [اضغط للزيارة](${result.url})\n\n`;
    
    formatted += `---\n\n`;
  });
  
  // إضافة معلومات الاستخدام إذا كان من Google
  if (source.includes('Google')) {
    const usage = usageTracker.getUsage();
    formatted += `\n📊 **استخدام API اليوم:** ${usage.used}/${usage.limit} استعلام (متبقي: ${usage.remaining})\n\n`;
  }
  
  formatted += `💡 تبي تفاصيل أكثر عن نتيجة معينة؟ أو تبي أبحث عن شيء آخر؟ 😊`;
  
  return formatted;
}

// 📤 Export النسخة المبسطة للتوافق مع الكود القديم
export const simpleSearchWeb = async (query: string): Promise<any> => {
  const result = await searchWeb(query);
  return {
    results: result.results,
    totalResults: result.totalResults,
    searchTime: result.searchTime,
    source: result.source
  };
};

